# The "Everything" Ignore List
# This tells Git to ignore these folders NO MATTER WHERE they are.

# Dependencies
node_modules
.venv
venv
env
ENV

# Build & Cache
dist
build
__pycache__
*.pyc
*.pyo
.Python

# Editor & IDEs
.vscode
.idea
.anima
*.swp
*.swo

# OS Junk
.DS_Store
Thumbs.db
desktop.ini

# Environment Secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel
