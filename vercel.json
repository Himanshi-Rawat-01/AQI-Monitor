{
  "version": 2,
  "builds": [
    {
      "src": "pollution-app/backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "pollution-app/react-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "pollution-app/backend/app.py"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "pollution-app/react-app/dashboard/$1"
    },
    {
      "src": "/dashboard",
      "dest": "pollution-app/react-app/dashboard/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "pollution-app/react-app/index.html"
    }
  ]
}
