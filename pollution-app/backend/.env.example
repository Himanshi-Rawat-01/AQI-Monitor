# AQI Monitor Environment Configuration
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
# Get your connection string from: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/enviro

# OpenWeatherMap API Key
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# JWT Secret Key (for authentication)
# In production, use a strong random secret!
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# Flask Configuration
FLASK_ENV=development
DEBUG=False

# CORS Configuration (if needed)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:5000

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
